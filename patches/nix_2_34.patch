+{
+    EvalState::TrackingScopeId scopeId = state.nextTrackingScopeId++;
+    EvalState::TrackingScope scope;
+    scope.id = scopeId;
+    scope.trackedBindings = nullptr;
+    state.trackingScopes.push_back(std::move(scope));
+    state.trackingActive = true;
+
+    v.mkInt(scopeId);
+}
