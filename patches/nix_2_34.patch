+void prim_tagThunkOrigin(EvalState & state, const PosIdx pos, Value ** args, Value & v)
+{
+    auto scopeId = state.forceInt(*args[0], pos, "while evaluating the first argument passed to builtins.tagThunkOrigin");
+    state.forceList(*args[1], pos, "while evaluating the second argument passed to builtins.tagThunkOrigin");
+
+    EvalState::TrackingAttrPath path;
+    for (auto elem : args[1]->listView()) {
+        state.forceStringNoCtx(*elem, pos, "while evaluating a path element in builtins.tagThunkOrigin");
+        path.push_back(state.symbols.create(elem->string_view()));
+    }
+
+    Value * thunk = args[2];
+    v = *thunk;
+    state.tagThunkOrigin(&v, scopeId.value, path);
+}
+
+static RegisterPrimOp primop_tagThunkOrigin({
+    .name = "__tagThunkOrigin",
+    .args = {"scopeId", "path", "thunk"},
+    .doc = R"(
+      Tag a thunk with its origin path for dependency tracking. When the tagged
+      thunk is forced, it pushes its origin as the accessor context so that
+      attribute accesses on tracked attrsets are recorded as dependencies.
+      Returns the thunk unchanged (does not force it).
+    )",
+    .impl = prim_tagThunkOrigin,
+    .experimentalFeature = Xp::DependencyTracking,
+});
+
+void prim_tagAttrThunkOrigin(EvalState & state, const PosIdx pos, Value ** args, Value & v)
+{
+    auto scopeId = state.forceInt(*args[0], pos, "while evaluating the first argument passed to builtins.tagAttrThunkOrigin");
+    state.forceList(*args[1], pos, "while evaluating the second argument passed to builtins.tagAttrThunkOrigin");
+
+    EvalState::TrackingAttrPath path;
+    for (auto elem : args[1]->listView()) {
+        state.forceStringNoCtx(*elem, pos, "while evaluating a path element in builtins.tagAttrThunkOrigin");
+        path.push_back(state.symbols.create(elem->string_view()));
+    }
+
+    auto attrName = state.forceStringNoCtx(*args[2], pos, "while evaluating the third argument passed to builtins.tagAttrThunkOrigin");
+    auto name = state.symbols.create(attrName);
+
+    state.forceAttrs(*args[3], pos, "while evaluating the fourth argument passed to builtins.tagAttrThunkOrigin");
+
+    auto * attr = args[3]->attrs()->get(name);
+    if (!attr)
+        state.error<EvalError>("attribute '%1%' not found in attrset", state.symbols[name]).atPos(pos).debugThrow();
+
+    state.tagThunkOrigin(attr->value, scopeId.value, path);
+    v = *args[3];
+}
+
+static RegisterPrimOp primop_tagAttrThunkOrigin({
+    .name = "__tagAttrThunkOrigin",
+    .args = {"scopeId", "path", "attrName", "attrset"},
+    .doc = R"(
+      Tag a specific attribute's thunk directly within an attrset's bindings.
+      Unlike `tagThunkOrigin`, this avoids creating a wrapper thunk by tagging
+      the stored value in-place. Returns the attrset unchanged.
+    )",
+    .impl = prim_tagAttrThunkOrigin,
+    .experimentalFeature = Xp::DependencyTracking,
+});
